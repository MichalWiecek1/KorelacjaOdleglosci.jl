function box_muller(n::Int)
    X₁ = rand(n)
    X₂ = rand(n)

    R = sqrt.(-2 .* log.(X₁))
    Θ = 2π .* X₂

    Y₁ = R .* cos.(Θ)
    Y₂ = R .* sin.(Θ)

    return X₁, X₂, Y₁, Y₂
end

