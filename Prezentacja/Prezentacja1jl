function dyskretyzacja(X, Y, typ_X::Symbol, typ_Y::Symbol)
    Xd = typ_X == :U ? bin_U(X) :
         typ_X == :N ? bin_N(X) :
         error("Nieznany typ X")

    Yd = typ_Y == :U ? bin_U(Y) :
         typ_Y == :N ? bin_N(Y) :
         error("Nieznany typ Y")

    return Xd, Yd
end

function wykonaj_testy(X, Y, typ_X::Symbol, typ_Y::Symbol;
                       iter)
    Xd, Yd = dyskretyzacja(X, Y, typ_X, typ_Y)
    
    p_szekely = p_value_Székely(X, Y, iter)

    p_zhang = p_value_Zhang(Xd, Yd, iter)

    return p_szekely, p_zhang
end

function generuj_przypadek(n::Int, numer::Int)

    if numer == 1
        # X,Y ~ U(0,1), niezależne
        X = rand(n)
        Y = rand(n)

        typ_X = :U
        typ_Y = :U

    elseif numer == 2
        # X ~ U(0,1), Y = 1-X
        X = rand(n)
        ε = sqrt(0.1) .* randn(n)
        Y = 1 .- X .+ ε

        typ_X = :U
        typ_Y = :N

    elseif numer == 3
        # Testujemy U₁ względem Y₁ z Boxa-Mullera
        X₁, X₂, Y₁, Y₂ = box_muller(n)

        X = vcat(X₁, X₂)
        Y = vcat(Y₁, Y₂)

        typ_X = :U
        typ_Y = :N

    elseif numer == 4
        # Testujemy Y₁ względem Y₂ z Boxa-Mullera
        X₁, X₂, Y₁, Y₂ = box_muller(n)

        X = Y₁
        Y = Y₂

        typ_X = :N
        typ_Y = :N

    else
        error("Numer przypadku musi należeć do 1:4")
    end

    return X, Y, typ_X, typ_Y
end

function symulacja_przypadku(numer::Int;
                             powt,
                             n,
                             iter)

    p_szekely = zeros(powt)
    p_zhang = zeros(powt)

    for r in 1:powt
        X, Y, typ_X, typ_Y = generuj_przypadek(n, numer)

        p_szekely[r], p_zhang[r] =
            wykonaj_testy(
                X,
                Y,
                typ_X,
                typ_Y;
                iter
            )
    end

    return p_szekely, p_zhang
end

