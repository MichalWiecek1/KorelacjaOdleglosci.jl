function dystrybuanta_z_bledem_II(
    p_wartosci;
    alpha = al,
    tytul = "Dystrybuanta empiryczna"
)
    m = length(p_wartosci)

    p_sort = sort(p_wartosci)
    F_emp = (1:m) ./ m

    moc = mean(p_wartosci .<= alpha)
    beta = 1 - moc

    wykres = plot(
        p_sort,
        F_emp,
        seriestype = :steppost,
        xlabel = "p-wartość",
        ylabel = "Dystrybuanta empiryczna",
        label = "dystrybuanta empiryczna",
        title = tytul,
        linewidth = 2,
        ylims = (0, 1.05)
    )

    vline!(
        wykres,
        [alpha],
        linestyle = :dash,
        linewidth = 2,
        label = "α = $alpha"
    )

    hline!(
        wykres,
        [moc],
        linestyle = :dash,
        linewidth = 2,
        label = "moc testu = $(round(moc, digits=3))"
    )

    println("Moc testu = ", round(moc, digits=4))
    println("Błąd II rodzaju = ", round(beta, digits=4))

    return wykres
end

