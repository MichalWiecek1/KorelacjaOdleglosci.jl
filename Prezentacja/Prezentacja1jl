function wykres_kwantylowy(p_wartosci;
                            tytul = "Wykres kwantylowy")

    m = length(p_wartosci)

    empiryczne = sort(p_wartosci)
    teoretyczne = ((1:m) .- 0.5) ./ m

    scatter(
        teoretyczne,
        empiryczne,
        xlabel = "Kwantyle teoretyczne U(0,1)",
        ylabel = "Kwantyle empiryczne p-wartości",
        title = tytul,
        label = "p-wartości",
        markersize = 3,
        xlims = (0, 1),
        ylims = (0, 1)
    )

    plot!(
        [0, 1],
        [0, 1],
        linestyle = :dash,
        linewidth = 2,
        label = "y = x"
    )
end

